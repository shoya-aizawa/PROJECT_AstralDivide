@echo off
::------------------------------------------------------------------------------
:: Splash.Border.bat
:: Renders the outer GUI frame and inner separator lines.
::------------------------------------------------------------------------------

if "%~1"=="Separator" (
    if /i "%SELECTED_FONT%"=="SimSun" (
        echo !esc![%~2;8H!C_BORDER!----------------------------------------------------------------!C_RESET!
    ) else (
        echo !esc![%~2;8H!C_BORDER!────────────────────────────────────────────────────────────────!C_RESET!
    )
    exit /b
)

echo !esc![1;1H!C_BORDER!╔══════════════════════════════════════════════════════════════════════════════╗
for /L %%i in (2,1,23) do (
    echo !esc![%%i;1H!C_BORDER!║!esc![%%i;80H!C_BORDER!║
)
echo !esc![24;1H!C_BORDER!╚══════════════════════════════════════════════════════════════════════════════╝
exit /b
